# ================================================
# KREATIVE VIT — Variables de Entorno (EJEMPLO)
# Copia este archivo como .env y llena tus datos
# ================================================

# Conexión a la BD de Kreative Vit
DB_HOST=localhost
DB_USER=tu_usuario_mysql
DB_PASS=tu_contraseña_mysql
DB_NAME=alphadocere_Vit
DB_PORT=3306

# cPanel / Hosting info
CPANEL_USER=tu_usuario_cpanel

# Configuración de la aplicación
SITE_URL=http://localhost
APP_NAME=Kreative Vit

# JWT (para comunicación interna si se necesita)
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRY=86400
